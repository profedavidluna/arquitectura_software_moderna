        "type": "object",
        "properties": {
          "orderId": {"type": "string", "format": "uuid"},
          "userId": {"type": "string", "format": "uuid"},
          "trackingNumber": {"type": "string"},
          "carrier": {"type": "string"},
          "shippedAt": {"type": "string", "format": "date-time"}
        }
      }
    },
    {
      "name": "order.cancelled",
      "partitions": 3,
      "replicationFactor": 2,
