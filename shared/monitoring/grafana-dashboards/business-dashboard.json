{
  "dashboard": {
    "id": null,
    "uid": "business-dashboard",
    "title": "Business Dashboard",
    "description": "Business KPIs and metrics - orders, revenue, conversion, payments, and user activity",
    "tags": ["business", "revenue", "analytics", "kpi"],
    "timezone": "browser",
    "schemaVersion": 37,
    "version": 2,
    "refresh": "1m",
    "editable": true,
    "panels": [
      {
        "id": 1,
        "title": "Orders Created (per hour)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(rate(orders_created_total[1h])) * 3600",
            "legendFormat": "Orders/hour",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}
          }
        }
      },
      {
        "id": 2,
        "title": "Total Revenue",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(orders_total_amount)",
            "legendFormat": "Total Revenue",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 10000},
                {"color": "green", "value": 50000}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "auto",
          "colorMode": "value"
        }
      },
      {
        "id": 3,
        "title": "Average Order Value",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(orders_total_amount) / sum(orders_created_total)",
            "legendFormat": "AOV",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "decimals": 2
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "auto"
        }
      },
      {
        "id": 4,
        "title": "Revenue Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(rate(orders_total_amount[1h])) * 3600",
            "legendFormat": "Revenue/hour",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20}
          }
        }
      },
      {
        "id": 5,
        "title": "Conversion Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "(sum(rate(orders_created_total[1h])) / sum(rate(carts_created_total[1h]))) * 100",
            "legendFormat": "Conversion Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 3}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 6,
        "title": "Active Users",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(users_active_total)",
            "legendFormat": "Active Users",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "textMode": "auto",
          "colorMode": "value"
        }
      },
      {
        "id": 7,
        "title": "Payment Success Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(rate(payment_attempts_total{status=\"success\"}[1h])) / sum(rate(payment_attempts_total[1h])) * 100",
            "legendFormat": "Success Rate",
            "refId": "A"
          },
          {
            "expr": "90",
            "legendFormat": "Alert Threshold (90%)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 90},
                {"color": "green", "value": 99}
              ]
            },
            "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Alert Threshold (90%)"},
              "properties": [
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
              ]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Payment Methods Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(rate(payment_attempts_total[24h])) by (payment_method)",
            "legendFormat": "{{payment_method}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "pieType": "donut",
          "legend": {"displayMode": "table", "placement": "right"}
        }
      },
      {
        "id": 9,
        "title": "User Registrations (per hour)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(rate(users_registered_total[1h])) * 3600",
            "legendFormat": "Registrations/hour",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"drawStyle": "bars", "fillOpacity": 50}
          }
        }
      },
      {
        "id": 10,
        "title": "Cart Abandonment Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 24},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "((sum(rate(carts_created_total[1h])) - sum(rate(orders_created_total[1h]))) / sum(rate(carts_created_total[1h]))) * 100",
            "legendFormat": "Abandonment Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 11,
        "title": "Inventory Stock Levels",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 24},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(inventory_quantity_available) by (product_category)",
            "legendFormat": "{{product_category}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
          }
        }
      },
      {
        "id": 12,
        "title": "Top Products by Sales",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "topk(10, sum(orders_product_quantity) by (product_name))",
            "legendFormat": "{{product_name}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"align": "auto"}
          }
        },
        "options": {
          "showHeader": true,
          "footer": {"show": false},
          "sortBy": [{"displayName": "Value", "desc": true}]
        },
        "transformations": [
          {"id": "organize", "options": {"excludeByName": {"Time": true}}}
        ]
      },
      {
        "id": 13,
        "title": "Order Status Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "targets": [
          {
            "expr": "sum(orders_by_status) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "options": {
          "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
          "pieType": "donut",
          "legend": {"displayMode": "table", "placement": "right"}
        }
      }
    ],
    "time": {"from": "now-24h", "to": "now"},
    "timepicker": {
      "refresh_intervals": ["1m", "5m", "15m", "30m", "1h"],
      "time_options": ["1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "templating": {
      "list": [
        {
          "name": "timeRange",
          "label": "Time Range",
          "type": "interval",
          "query": "1h,6h,12h,24h,2d,7d,30d",
          "refresh": 2,
          "current": {"text": "24h", "value": "24h"}
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Business Alerts",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "enable": true,
          "expr": "ALERTS{alertstate=\"firing\", category=\"business\"}",
          "titleFormat": "{{alertname}}",
          "textFormat": "{{description}}",
          "tagKeys": "severity"
        }
      ]
    },
    "links": [
      {"title": "System Dashboard", "url": "/d/system-dashboard", "type": "dashboard"},
      {"title": "Application Dashboard", "url": "/d/application-dashboard", "type": "dashboard"},
      {"title": "Service Health Dashboard", "url": "/d/service-health-dashboard", "type": "dashboard"}
    ]
  }
}
